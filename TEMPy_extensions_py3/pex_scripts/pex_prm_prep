#!/usr/bin/env python3
import sys as _sys, os as _os
_sys.path.insert(0, _os.path.dirname(_os.path.dirname(_os.path.abspath(__file__))))
import argparse


def main():
    from easy_peet_prep import prep_prm

    parser = argparse.ArgumentParser(
        description=(
            'Build an initial PEET prm file from a list of model file softlinks. '
            'Tomograms are located automatically by matching each model\'s coordinate '
            'extent (read from the IMOD binary header) against MRC files in the same '
            'directory as the resolved model. The smallest fitting volume is chosen. '
            'Use --tomo_ext to disambiguate when multiple candidates are found.'
        )
    )
    parser.add_argument('mod_list', help='Text file listing model file paths, one per line. '
                        'e.g. ls *.mod > list.txt')
    parser.add_argument('out_dir', help='Output directory for the prm file (created if absent).')
    parser.add_argument('--tomo_ext',
                        help='Filename suffix used to disambiguate when multiple tomograms '
                             'match the model dimensions (e.g. _b4_rec.mrc, _rec.mrc). '
                             'Not required when the match is unambiguous.',
                        default=None)
    parser.add_argument('--exclude_kw',
                        help='Comma-separated substrings: tomograms whose paths contain any '
                             'of these are ignored. Default: fakesirt,bp,full',
                        default='fakesirt,bp,full')
    parser.add_argument('--box_size', help='Reference box size (3 ints, X Y Z).',
                        default=[48, 48, 48], nargs=3, type=int)
    parser.add_argument('--linpick_sampling',
                        help='Run pex_linear_pick with this voxel sampling and use the '
                             'resulting model instead of the input model. Off by default.',
                        default=None)
    args = parser.parse_args()

    exclude_str = args.exclude_kw.split(',')
    do_linpick = args.linpick_sampling is not None
    prep_prm(args.mod_list, args.out_dir, ref=False,
             linpick_sampling=args.linpick_sampling,
             extension=args.tomo_ext,
             excluded_tomo_kw=exclude_str,
             box_size=args.box_size, base_name='m', do_linpick=do_linpick)



if __name__ == '__main__':
    main()
