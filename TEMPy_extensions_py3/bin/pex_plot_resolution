import os
from os.path import split, join, realpath
import glob
from subprocess import check_output
import numpy as np
import matplotlib.pyplot as plt
import argparse
from PEET_matlab_trans_fn import fsc
import mrcfile




def get_vols(path, base = False):
    os.chdir(path)
    if base:
        unm = glob.glob('%s*.mrc')
        ma = []
    else:
        unm = glob.glob('unMasked*_Ref?.mrc') + glob.glob('unMasked*_Ref??.mrc')
        unm = [realpath(x) for x in unm]
    if len(unm) < 1:
        raise Exception('No averages found in %s' % path)
    if not base:
        bn = split(unm[0])[1].split('_')[0][8:]
        ma = glob.glob('%s_Ref?.mrc' % (bn)) + glob.glob('%s_Ref??.mrc' % (bn))
        ma = [realpath(x) for x in ma]
        unm = sorted(unm)
        ma = sorted(ma)
    return unm, ma

def plot_res(path1, path2, base = False, use_unmasked = False, edgeWidth = 2):
    u1, m1 = get_vols(path1, base = base)
    u2, m2 = get_vols(path2, base = base)
    if base or use_unmasked:
        v1 = u1
        v2 = u2
        winName = '1'
    else:
        v1 = m1
        v2 = m2
        winName = None

    apix = float(check_output('header -p %s' % v1[0], shell = True).decode().split()[0])
    labels = [split(x)[1] for x in v1]
    a = []
    for x in range(min(len(u1), len(u2))):
        ar1 = mrcfile.open(v1[x]).data
        ar2 = mrcfile.open(v2[x]).data
        ta, fs = fsc(ar1, ar2, fShells = False, edgeWidth = edgeWidth, winName = winName)
        a.append(ta)
    xt = apix/fs
    la = []
    for x in range(len(xt)):
        if len(str(np.round(xt[x])).split('.')[0]) > 1:
            la.append(int(np.round(xt[x])))
        else:
            la.append(np.round(xt[x], decimals = 1))

    la = la[::4]
    ff, ax = plt.subplots()
    ax.set_xticks(fs[::4])
    ax.set_xticklabels(la)
    ax.axhline(y = 0.143, c = 'k', linewidth = 0.5, ls = '--')
    ax.axhline(y = 0.5, c = 'k', linewidth = 0.5, ls = '--')
    
    for x in range(len(a)): 
        ax.plot(fs, a[x], label = labels[x], alpha = 0.5)
    ff.legend()
    plt.show()
    plt.savefig('fsc.png')


parser = argparse.ArgumentParser()
parser.add_argument('dir1', help = 'Path to directory containing PEET averages')
parser.add_argument('dir2')
parser.add_argument('--use_unmasked', action = 'store_true', default = False, help = 'Use unmasked averages')
parser.add_argument('--base_name', help = 'Averages have non-standard name. Search for base_name*.mrc instead', default = False)
parser.add_argument('--edge_width', help = 'Padding width', default = 2, type = int)
args = parser.parse_args()

plot_res(args.dir1, args.dir2, base = args.base_name, use_unmasked = args.use_unmasked, edgeWidth = args.edge_width)
        
        
