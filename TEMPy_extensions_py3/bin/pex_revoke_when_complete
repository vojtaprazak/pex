#!/usr/bin/env python
import os
from time import sleep
import sys
from subprocess import check_output, Popen, PIPE
import argparse


def revoke_on_completion(path, jobid = False, no_cleanup = False):
    path = os.path.realpath(path)
    if not os.path.split(path)[1] == 'processchunks.out':
        path = os.path.join(path, 'processchunks.out')
    while not os.path.isfile(path):
        sys.stdout.write('\rprocesschunks.out not found, waiting...')
        sys.stdout.flush()
        sleep(1)
    peetdir = os.path.split(path)[0]
    os.chdir(peetdir)
    if jobid:
        if not str(jobid) in [x.decode() for x in check_output('squeue -u %s' % os.getlogin(), shell = True).split()]:
            sys.exit('job ID %s not active' % jobid)
    
    
    cmd = ['tail', '-f', path]
    process = Popen(cmd, stdout = PIPE, stderr = PIPE,
                            preexec_fn=os.setsid)

    last_chunk_tracker = 0
    revoke=False
    running=False
    for line in iter(process.stdout.readline, ''.encode()):
        if line:
            line = line.decode()
            if (line.find('exitCode:1') != -1 or
                    line.find('ERROR: ALL MACHINES HAVE BEEN DROPPED DUE TO FAILURES') == 0):
                revoke = True
            elif (line.find('exitCode:0') != -1 or
                line.find('Finished reassembling') != -1):
                revoke = True
            else:
                if not running:
                    print('\nPEET running...')
                    running = True
                if line.find('DONE SO FAR') != -1:
                    chunknum = line.split(' ')[0]
                    if chunknum.isdigit():
                        last_chunk_tracker = max(last_chunk_tracker, int(chunknum))
                    
                if last_chunk_tracker != 0:
                    sys.stdout.write('\rLast completed chunk %s.' % last_chunk_tracker)
                    sys.stdout.flush()
            if (line.find('Killing jobs on') != -1
                or line.find('exitCode:2') != -1):
                print('\nPEET terminated. Exiting...')
                sys.exit()
                
                
        if revoke:
            print('\nPEET done, deleting comfiles...')
            if not no_cleanup:
                try:
                    print('Removing .com and .log files...')
                    check_output("rm *-*.log *-*.com *-*.log~ *-*.com~", shell = True)
                except:
                    pass
            print('Warning: Revoking nodes in 60s. Press CTRL-C to abort.\n')
            sleep(60)
            if jobid:
                print('\nTerminating job %s' % jobid)
                check_output('scancel %s' % jobid, shell = True)
            else:
                print('\nTerminating user %s jobs' % os.getlogin())
                check_output('scancel -u %s' % os.getlogin(), shell = True)
            sys.exit()



parser = argparse.ArgumentParser(description=('Terminate slurm allocation after PEET terminates. If JOBID is not specified, all user jobs are terminated. Also removes temporary .com and .log files.'))
parser.add_argument('path', help='Path to PEET project directory/')
parser.add_argument('--jobid', type=int, default = False, help='Slurm job ID to be terminated.')
parser.add_argument('--no_cleanup', default = False, action = 'store_true', help='Do not cleanup temporary .com and log files (not recommended).')
args = parser.parse_args()
revoke_on_completion(args.path, args.jobid, args.no_cleanup)


